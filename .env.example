# lebeSsni — Variables d'environnement (backend)
# Copier vers .env et remplir les valeurs

# App
APP_NAME=lebeSsni
APP_VERSION=2.1.0
DEBUG=false

# Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.chtuhujoxuypuckrvhbf.supabase.co:5432/postgres

# Sécurité
JWT_SECRET=change-me-to-a-random-secret
API_KEY=change-me-to-an-api-key

# RunPod (moteur IA — optionnel, MOCK par defaut)
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Uploads
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=10
IMAGE_RETENTION_HOURS=24
